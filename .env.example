# ─────────────────────────────────────────────────────────────
# FitMirror — environment variables example
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values for your setup.
#   cp .env.example .env
#
# IMPORTANT: never commit your real .env — it's gitignored.
# Only this .env.example template is safe to share/commit.
# ─────────────────────────────────────────────────────────────


# ── Backend selector ─────────────────────────────────────────
# "prisma"     → use Prisma + SQLite (default, zero external deps)
# "pocketbase" → use a PocketBase instance (set POCKETBASE_* below)
BACKEND="prisma"


# ── Database (Prisma / SQLite) ───────────────────────────────
# Used when BACKEND=prisma. SQLite file path (Prisma). Relative to root.
# Run `bun run db:push` on first setup to create the schema.
DATABASE_URL="file:/home/z/my-project/db/custom.db"


# ── PocketBase backend ───────────────────────────────────────
# Used when BACKEND=pocketbase. Point at your PocketBase instance.
# First-time setup:
#   1. Start PocketBase:  cd mini-services/pocketbase && ./pocketbase serve
#   2. Create superuser:  ./pocketbase superuser upsert admin@fitmirror.local 'fitmirror-admin-2024'
#   3. Create collections: node setup.mjs
#   4. (optional) sync existing Prisma data:  bun run scripts/sync-to-pocketbase.ts
# Then set BACKEND=pocketbase here and restart the app.
POCKETBASE_URL="http://127.0.0.1:8090"
POCKETBASE_ADMIN_EMAIL="admin@fitmirror.local"
POCKETBASE_ADMIN_PASSWORD="fitmirror-admin-2024"


# ── Admin (app) credentials ──────────────────────────────────
# Default: admin / fitmirror2024 — change from Admin → API & Settings.
# ADMIN_USERNAME="admin"
# ADMIN_PASSWORD="fitmirror2024"


# ── AI Provider (Z.ai SDK) ───────────────────────────────────
# In the Z.ai sandbox the SDK is pre-configured — no key needed.
# For self-hosted deployments:
# ZAI_API_KEY=""
# ZAI_API_BASE=""


# ── Dodo Payments ────────────────────────────────────────────
# Add from Admin → API & Settings (stored in DB) or here.
# DODO_API_KEY=""
# DODO_WEBHOOK_SECRET=""
# DODO_ENABLED="false"


# ── App ──────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
