# ─────────────────────────────────────────────────────────────
# FitMirror — environment variables example
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values for your setup.
#   cp .env.example .env
#
# IMPORTANT: never commit your real .env — it's gitignored.
# Only this .env.example template is safe to share/commit.
# ─────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────
# SQLite file path (used by Prisma). Relative to project root.
# On first run, run `bun run db:push` to create the schema.
DATABASE_URL="file:/home/z/my-project/db/custom.db"


# ── Admin ─────────────────────────────────────────────────────
# Default admin password for the /admin console.
# Used only until you change it from Admin → API & Settings.
# Override here for deployments, or leave to use the default below.
# DEFAULT_ADMIN_PASSWORD="fitmirror2024"


# ── AI Provider (Z.ai SDK) ────────────────────────────────────
# In the Z.ai sandbox the SDK is pre-configured — no key needed.
# For a self-hosted deployment, provide your Z.ai credentials:
# ZAI_API_KEY=""
# ZAI_API_BASE=""


# ── App ───────────────────────────────────────────────────────
# Node environment (development | production)
NODE_ENV="development"

# Port the dev server runs on (Z.ai sandbox requires 3000)
PORT="3000"


# ── Payments (future) ─────────────────────────────────────────
# When you wire real payments, add your provider keys here.
# They can also be added from Admin → API & Settings (stored in DB).
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PUBLISHABLE_KEY=""
