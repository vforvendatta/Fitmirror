// FitMirror — AI Virtual Try-On Studio
// Prisma schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Anonymous browser session (cookie + localStorage). No login friction.
model Session {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  lastActive DateTime @default(now())
  plan       String   @default("free") // "free" | "pro" | "premium"

  tryOns       TryOn[]
  wardrobe     WardrobeItem[]
  usageLogs    UsageLog[]
  payments     Payment[]
}

/// Key-value store for admin-configurable settings (admin password, provider toggles, etc.).
model AdminSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Recorded payment for a plan upgrade (mock processor — always succeeds in this sandbox).
model Payment {
  id                 String   @id @default(cuid())
  sessionId          String
  session            Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  amountCents        Int
  currency           String   @default("USD")
  plan               String
  status             String   @default("succeeded")
  // Payment provider info (added for Dodo Payments integration).
  // Nullable so existing manual/admin payments keep working unchanged.
  provider           String?  // "dodo" | "manual" | ...
  providerPaymentId  String?  // provider's payment_id (e.g. Dodo's payment_id)
  createdAt          DateTime @default(now())

  @@index([sessionId])
  @@index([providerPaymentId])
}

/// A single try-on generation run.
model TryOn {
  id              String   @id @default(cuid())
  sessionId       String
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Stored as URL paths under /uploads (files on disk)
  personImageUrl  String
  garmentImageUrl String
  resultImageUrl  String?
  garmentName     String?
  // JSON-serialized StyleReport
  report          String?
  createdAt       DateTime @default(now())

  wardrobeItems WardrobeItem[]

  @@index([sessionId])
}

/// Saved look (from a TryOn the user liked).
model WardrobeItem {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tryOnId    String?
  tryOn      TryOn?   @relation(fields: [tryOnId], references: [id], onDelete: SetNull)
  name       String
  notes      String?
  // Snapshot of image URLs so wardrobe survives even if tryOn deleted
  personImageUrl  String?
  garmentImageUrl String?
  resultImageUrl  String?
  createdAt  DateTime @default(now())

  @@index([sessionId])
}

/// Daily usage counter per session (for free-tier limiting).
model UsageLog {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD (UTC)
  count     Int      @default(0)

  @@unique([sessionId, date])
  @@index([sessionId])
}
